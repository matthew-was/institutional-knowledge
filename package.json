{
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:backend": "pnpm --filter backend test",
    "test:backend:coverage": "pnpm --filter backend test:coverage",
    "test:frontend": "pnpm --filter frontend test",
    "test:frontend:coverage": "pnpm --filter frontend test:coverage",
    "test:frontend:e2e": "pnpm --filter frontend test:e2e",
    "test:frontend:e2e:coverage": "pnpm --filter frontend test:e2e:coverage",
    "typecheck": "pnpm -r typecheck",
    "typecheck:backend": "pnpm --filter backend typecheck",
    "typecheck:frontend": "pnpm --filter frontend typecheck",
    "lint": "pnpm -r lint",
    "lint:backend": "pnpm --filter backend lint",
    "lint:frontend": "pnpm --filter frontend lint",
    "testAll": "pnpm lint && pnpm typecheck && pnpm test",
    "testAll:backend": "pnpm lint:backend && pnpm typecheck:backend && pnpm test:backend",
    "testAll:frontend": "pnpm lint:frontend && pnpm typecheck:frontend && pnpm test:frontend"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "msw",
      "sharp"
    ]
  }
}
