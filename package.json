{
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:backend": "pnpm --filter backend test",
    "typecheck": "pnpm -r typecheck",
    "typecheck:backend": "pnpm --filter backend typecheck",
    "lint": "pnpm -r exec biome check",
    "lint:backend": "pnpm --filter backend exec biome check",
    "testAll": "pnpm lint && pnpm typecheck && pnpm test",
    "testAll:backend": "pnpm lint:backend && pnpm typecheck:backend && pnpm test:backend"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "typescript": "5.9.3"
  }
}
