{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		// Required: Express is a CJS module with no ESM default export.
		// Without this, `import express from "express"` fails under module: NodeNext.
		"esModuleInterop": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
