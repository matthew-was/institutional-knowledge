		"zod": "3.24.1"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/express": "5.0.1",
		"@types/multer": "1.4.12",
		"@types/nconf": "0.10.7",
		"@types/node": "22.13.10",
		"@types/pg": "8.11.11",
		"@types/uuid": "10.0.0",
