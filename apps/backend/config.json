{
  "server": {
    "port": 4000
  },
  "db": {
    "host": "postgres",
    "port": 5432,
    "database": "institutional_knowledge",
    "user": "ik_user",
    "password": "ik_local_dev"
  },
  "auth": {
    "frontendKey": "dev-frontend-key",
    "pythonKey": "dev-python-key",
    "pythonServiceKey": "dev-python-service-key"
  },
  "storage": {
    "provider": "local",
    "local": {
      "basePath": "./data/storage",
      "stagingPath": "./data/staging"
    }
  },
  "upload": {
    "maxFileSizeMb": 50,
    "acceptedExtensions": [
      ".pdf",
      ".jpg",
      ".jpeg",
      ".png",
      ".tiff",
      ".tif"
    ]
  },
  "pipeline": {
    "runningStepTimeoutMinutes": 30,
    "maxRetries": 3
  },
  "python": {
    "baseUrl": "http://processing:8000"
  },
  "vectorStore": {
    "provider": "pgvector"
  },
  "graph": {
    "provider": "postgresql"
  },
  "embedding": {
    "dimension": 384
  },
  "ingestion": {
    "partialAuditReport": false,
    "reportOutputDirectory": "./data/reports"
  }
}
