{
  "PROCESSING": {
    "OCR": {
      "PROVIDER": "docling",
      "QUALITY_THRESHOLD": 60.0,
      "QUALITY_SCORING": {
        "CONFIDENCE_WEIGHT": 0.7,
        "DENSITY_WEIGHT": 0.3,
        "TARGET_CHARS_PER_PAGE": 1800
      }
    },
    "LLM": {
      "PROVIDER": "ollama",
      "BASE_URL": "http://localhost:11434",
      "MODEL": "llama3.2",
      "CHUNKING_MIN_TOKENS": 100,
      "CHUNKING_MAX_TOKENS": 500
    },
    "EMBEDDING": {
      "PROVIDER": "ollama",
      "BASE_URL": "http://localhost:11434",
      "MODEL": "CHANGE_ME",
      "DIMENSION": 384
    },
    "METADATA": {
      "EXTRACTOR": "regex",
      "PATTERNS": {
        "DOCUMENT_TYPE": [
          "(?i)last will and testament",
          "(?i)\\bdeed of conveyance\\b",
          "(?i)\\bmortgage deed\\b",
          "(?i)\\bletter\\b",
          "(?i)\\bdeed\\b",
          "(?i)\\bwill\\b",
          "(?i)\\binvoice\\b",
          "(?i)\\bmortgage\\b"
        ],
        "DATES": [
          "\\b\\d{1,2}[\\/\\-]\\d{1,2}[\\/\\-]\\d{2,4}\\b",
          "\\b(?:January|February|March|April|May|June|July|August|September|October|November|December)\\s+\\d{1,2},?\\s+\\d{4}\\b",
          "\\b\\d{4}\\b",
          "\\d{1,2}(?:st|nd|rd|th)?\\s+[A-Za-z]+\\s+\\d{4}"
        ],
        "PEOPLE": [
          "\\b(?:Mr|Mrs|Miss|Dr|Rev)\\.?\\s+[A-Z][a-z]+(?:\\s+[A-Z][a-z]+)*\\b",
          "\\b[A-Z][a-z]+\\s+[A-Z][a-z]+\\b"
        ],
        "ORGANISATIONS": [
          "\\b(?:[A-Z][a-z]+\\s+)+(?:Ltd|Limited|Co|Company|Council|Association|Society|Bank)\\b"
        ],
        "LAND_REFERENCES": [
          "\\bLot\\s+\\d+\\b",
          "\\bSection\\s+\\d+\\b",
          "\\bBlock\\s+\\d+\\b",
          "\\b\\d+\\s+acres?\\b"
        ],
        "DESCRIPTION": [
          "(?i)re:\\s*([^.\\n]+)",
          "(?i)subject:\\s*([^.\\n]+)"
        ]
      },
      "COMPLETENESS_THRESHOLD": 50.0,
      "COMPLETENESS_WEIGHTS": {
        "DOCUMENT_TYPE": 0.2,
        "DATES": 0.2,
        "PEOPLE": 0.15,
        "ORGANISATIONS": 0.15,
        "LAND_REFERENCES": 0.15,
        "DESCRIPTION": 0.15
      }
    },
    "PIPELINE": {
      "RUNNING_STEP_TIMEOUT_MINUTES": 30
    }
  },
  "QUERY": {
    "ROUTER": "passthrough",
    "LLM": {
      "PROVIDER": "ollama",
      "BASE_URL": "http://localhost:11434",
      "MODEL": "llama3.2"
    },
    "VECTOR_SEARCH": {
      "TOP_K": 20
    },
    "CONTEXT_ASSEMBLY": {
      "TOKEN_BUDGET": 4000,
      "INCLUDE_PARENT_METADATA": true
    },
    "SYNTHESIS": {
      "LLM": {
        "PROVIDER": "ollama",
        "BASE_URL": "http://localhost:11434",
        "MODEL": "llama3.2"
      },
      "CITATION_FIELDS": [
        "DOCUMENT_TYPE",
        "DATES",
        "PEOPLE",
        "ORGANISATIONS"
      ]
    }
  },
  "AUTH": {
    "INBOUND_KEY": "dev-python-service-key",
    "EXPRESS_KEY": "dev-python-key"
  },
  "SERVICE": {
    "EXPRESS_BASE_URL": "http://localhost:4000",
    "HTTP": {
      "RETRY_COUNT": 3,
      "RETRY_DELAY_MS": 500
    }
  }
}
