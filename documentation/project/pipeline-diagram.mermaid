%% ============================================================
%% DIAGRAM 1: System Overview
%% High-level components and data flow. No internal detail.
%% ============================================================

graph LR
    Archivist([Primary Archivist])

    subgraph Frontend["Next.js Frontend"]
        WebUI[Web UI]
    end

    subgraph C1["C1: Document Intake"]
        Intake[Intake\nValidate · Stage · Store]
    end

    subgraph BackendSvc["Express Backend"]
        API[API]
        DB[(PostgreSQL\n+ pgvector)]
        FileStore[(File Storage)]
    end

    subgraph C2["C2: Processing\n(Python service)"]
        Processing[OCR · Chunk · Embed\nMetadata · Vocabulary]
    end

    subgraph C3["C3: Query"]
        Query[Embed · Search\nRAG · Respond]
    end

    C4["C4: Continuous Ingestion\n(Phase 2+)"]

    Archivist -->|"Upload / curate"| WebUI
    Archivist -->|"Bulk ingest / query"| API
    WebUI --> API
    API --> Intake
    Intake --> DB
    Intake --> FileStore
    API -->|"Trigger"| Processing
    Processing -->|"Results"| API
    API --> DB
    FileStore -.->|"File ref"| Processing
    API --> Query
    DB -.->|"Embeddings\n+ metadata"| Query
    FileStore -.->|"Source docs"| Query
    Query -->|"Response + citations"| API
    C4 -.->|"Phase 2+"| API

    style C4 fill:#f0f0f0,stroke-dasharray: 5 5
    style DB fill:#99d6ff
    style FileStore fill:#99d6ff
    style Archivist fill:#ffb366


%% ============================================================
%% DIAGRAM 2: C1 — Document Intake Detail
%% Two intake routes, validation, staging, and file lifecycle.
%% ============================================================

graph TD
    Archivist([Primary Archivist])
    WebUI[Web UI\nNext.js]
    CLI[CLI]

    subgraph WebRoute["Web UI Upload — ADR-007, ADR-017"]
        Initiate["1. Initiate\nCreate DB record\nstatus: initiated"]
        Upload["2. Upload\nWrite to staging area\nstatus: uploaded"]
        Store["3. Store\nMove to permanent storage\nHash validated\nstatus: stored"]
        Finalize["4. Finalize\nAll files confirmed\nstatus: finalized"]
    end

    subgraph BulkRoute["Bulk Ingestion CLI — ADR-018, ADR-020, ADR-035"]
        RunStart["Run Start\nGenerate run ID\nCreate staging directory\nOpen report file"]
        FileVal["Per-File Validation\nNaming convention\nFormat · Size · Hash\nADR-009, ADR-035"]
        BatchMove["Batch Move\nstagingpermanent storage\nPer-file: uploadedstored"]
        RunComplete["Run Complete\nAll files: stored→finalized\nWrite summary report\nDelete staging directory"]
    end

    subgraph Cleanup["Startup / Run-Start Sweep — ADR-010, ADR-017, ADR-018"]
        Sweep["Status-aware cleanup\ninitiated / uploaded → delete record + wipe staging\nstored (not finalized) → delete from storage + delete record"]
    end

    DB[(PostgreSQL)]
    Storage[(File Storage)]

    Archivist --> WebUI
    Archivist --> CLI
    WebUI --> Initiate
    Initiate --> Upload
    Upload --> Store
    Store --> Finalize
    Initiate -->|"DB record"| DB
    Store -->|"File"| Storage
    Finalize -->|"Update status"| DB

    CLI --> RunStart
    RunStart --> FileVal
    FileVal --> BatchMove
    BatchMove --> RunComplete
    RunStart -->|"Run record"| DB
    BatchMove -->|"Files"| Storage
    RunComplete -->|"Update statuses"| DB

    Sweep -.->|"On startup / run start"| DB
    Sweep -.->|"Cleanup"| Storage

    style DB fill:#99d6ff
    style Storage fill:#99d6ff
    style Archivist fill:#ffb366
    style Sweep fill:#fff0cc


%% ============================================================
%% DIAGRAM 3: C2 — Processing Pipeline Detail
%% Express trigger, Python steps, result write-back.
%% ============================================================

graph TD
    API["Express API\n(processing trigger)"]
    FileStore[(File Storage)]
    DB[(PostgreSQL\n+ pgvector)]

    subgraph PipelineTracker["Pipeline Step Tracker — ADR-027"]
        MarkRunning["Mark steps running\nRecord started_at"]
        StaleCheck["Stale-running sweep\n> pipeline.runningStepTimeoutMinutes\n→ reset to failed"]
        MarkDone["Update steps\ncompleted / failed\nincrement attempt count"]
    end

    subgraph Python["Python Processing Service — ADR-015"]
        OCR["Text Extraction\nDocling (primary)\nTesseract (fallback)\nADR-011"]
        Quality["Quality Scoring\nPer-page OCR confidence\n+ text density\nADR-021"]
        MetaDetect["Metadata Extraction\nType · Dates · People\nLand refs · Description\nPattern-based — ADR-012"]
        Completeness["Completeness Scoring\nWeighted field presence\nPluggable interface\nADR-021"]
        VocabCandidate["Vocabulary Candidates\nProposed terms\nfor review queue\nADR-014"]
        Chunking["Semantic Chunking\nLLM-based\nOllama / API LLM\nADR-025"]
        Embedding["Embedding Generation\nLocal model\nConfig-driven dimensions\nADR-024"]
    end

    subgraph TxWrite["Express Transaction Write — ADR-031"]
        TxWriter["Single transaction:\nChunks + embeddings\nPipeline step status\nVocabulary candidates\nQuality scores"]
        VectorStore["VectorStore Interface\nADR-033"]
    end

    API -->|"Fire-and-forget\nreturns run ID\nADR-026"| StaleCheck
    StaleCheck --> MarkRunning
    MarkRunning -->|"Document ID\n+ file reference\nADR-031"| OCR
    FileStore -.->|"File path / URI"| OCR

    OCR --> Quality
    Quality --> MetaDetect
    MetaDetect --> Completeness
    Completeness --> VocabCandidate
    VocabCandidate --> Chunking
    Chunking --> Embedding

    Embedding -->|"Structured response\nHTTP/RPC"| TxWriter
    TxWriter --> DB
    TxWriter --> VectorStore
    VectorStore -->|"pgvector Phase 1\nswappable via config"| DB
    TxWriter --> MarkDone

    style DB fill:#99d6ff
    style FileStore fill:#99d6ff
    style VectorStore fill:#e8d5ff
    style StaleCheck fill:#fff0cc


%% ============================================================
%% DIAGRAM 4: C3 — Query and Retrieval Detail
%% Embedding, vector search, RAG, citations.
%% ============================================================

graph TD
    Archivist([Primary Archivist])
    CLI[CLI\n(Phase 1)]
    WebUI[Web UI\n(Phase 2)]
    API["Express API"]
    DB[(PostgreSQL\n+ pgvector)]
    FileStore[(File Storage)]

    subgraph QueryFlow["Query and Retrieval — C3"]
        QueryEmbed["Query Embedding\nSame model as C2\nADR-024"]
        VectorStore["VectorStore Interface\nADR-033"]
        VectorSearch["Similarity Search\npgvector Phase 1"]
        Rerank["Chunk + Document\nContext Assembly"]
        RAG["RAG\nLLM synthesis"]
        Response["Response\nWith citations\nYYYY-MM-DD — description\nor [undated] — description\nADR-023"]
    end

    Archivist --> CLI
    Archivist --> WebUI
    CLI -->|"Natural language query"| API
    WebUI -->|"Natural language query\n(Phase 2)"| API
    API --> QueryEmbed
    QueryEmbed --> VectorStore
    VectorStore -->|"similarity search"| VectorSearch
    DB -->|"Embeddings"| VectorSearch
    VectorSearch --> Rerank
    DB -->|"Document metadata\n+ chunk text"| Rerank
    FileStore -.->|"Source documents\n(Phase 2)"| Rerank
    Rerank --> RAG
    RAG --> Response
    Response -->|"Answer + citations"| API
    API -->|"Response"| CLI
    API -->|"Response"| WebUI

    style DB fill:#99d6ff
    style FileStore fill:#99d6ff
    style VectorStore fill:#e8d5ff
    style Response fill:#a8d5a8
    style Archivist fill:#ffb366
