graph TD
    %% External Actors
    Archivist([Primary Archivist])
    WebUI[Web UI\nNext.js]
    CLI[CLI]

    %% Component 1: Document Intake
    subgraph C1["Component 1: Document Intake"]
        WebUpload["Web UI Upload\nFour-status lifecycle\nADR-007, ADR-017"]
        BulkIngest["Bulk Ingestion CLI\nRun-level staging + run ID\nADR-018, ADR-020, ADR-035"]
        Validate["Validation\nFormat, size, hash\nADR-009"]
        Staging[("Staging Area\n(per-upload or per-run)")]
    end

    %% Shared Infrastructure
    subgraph Infra["Shared Infrastructure"]
        DB[("PostgreSQL + pgvector\nADR-004")]
        Storage[("File Storage\nLocal / S3\nADR-008")]
        ExpressConfig[/"Express Config File\n(DB + storage + backend)\nADR-015, ADR-016"/]
        PythonConfig[/"Python Config File\n(OCR + LLM + embedding)\nADR-015, ADR-016"/]
    end

    %% Express Backend
    subgraph Backend["Express Backend — Sole DB Writer (ADR-031)"]
        API["Express API\nIntake + Processing trigger + Query"]
        Knex["Knex.js Migrations\nADR-028, ADR-029"]
        TxWriter["Transaction Writer\nAtomic writes"]
        VectorStore["VectorStore Interface\nADR-033"]
        PipelineTracker["Pipeline Step Tracker\npipeline_steps table\nStale-running sweep\nADR-027"]
    end

    %% Component 2: Text Extraction, Processing and Embedding
    subgraph C2["Component 2: Processing (Python Docker Service — ADR-015)"]
        OCR["Text Extraction\nDocling / Tesseract\nADR-011"]
        Quality["Quality Scoring\nPer-page + whole-doc\nADR-021"]
        MetaDetect["Metadata Extraction\nPattern-based detection\nADR-012"]
        Completeness["Completeness Scoring\nWeighted field presence\nADR-021"]
        VocabCandidate["Vocabulary Candidate\nIdentification\nADR-014"]
        Chunking["Semantic Chunking\nLLM-based\nADR-025"]
        Embedding["Embedding Generation\nLocal model\nConfig-driven dimensions\nADR-024"]
    end

    %% Component 3: Query and Retrieval
    subgraph C3["Component 3: Query and Retrieval"]
        QueryEmbed["Query Embedding\n(same model as C2)"]
        VectorSearch["Vector Similarity Search\nvia VectorStore interface\nADR-033"]
        RAG["RAG Context Assembly\n+ LLM"]
        Response["Response with Citations\nYYYY-MM-DD — description\nADR-023"]
    end

    %% Phase 2+ Component 4
    subgraph C4["Component 4: Continuous Ingestion (Phase 2+)"]
        AutoTrigger["Automated Triggers\nLISTEN/NOTIFY candidate\nADR-026"]
    end

    %% Archivist interactions
    Archivist --> WebUI
    Archivist --> CLI

    %% Intake flows
    WebUI --> API
    CLI -->|"Bulk ingestion\n(--grouped, ADR-020, ADR-035)"| BulkIngest
    CLI -->|"Query"| API
    API --> WebUpload
    WebUpload --> Validate
    BulkIngest --> Validate
    Validate --> Staging
    Staging -->|"Move to permanent storage\ninitiated → uploaded → stored → finalized\nADR-007, ADR-017, ADR-018"| Storage

    %% Processing trigger
    API -->|"Fire-and-forget trigger\nreturns run ID\nADR-026"| PipelineTracker
    PipelineTracker -->|"Mark steps running\nstale-running sweep\nADR-027"| OCR

    %% Processing pipeline (sequential within Python service)
    OCR --> Quality
    Quality --> MetaDetect
    MetaDetect --> Completeness
    Completeness --> VocabCandidate
    VocabCandidate --> Chunking
    Chunking --> Embedding

    %% Python returns results to Express
    Embedding -->|"Structured response\nvia HTTP/RPC\nADR-031"| TxWriter

    %% Express writes to DB
    TxWriter --> DB
    TxWriter --> VectorStore
    VectorStore -->|"pgvector Phase 1\nswappable via config\nADR-033"| DB
    Knex -->|"Schema management"| DB
    API --> TxWriter

    %% File references
    Storage -.->|"File reference\n(path or URI)\nADR-031"| OCR
    Storage -.->|"Original docs"| RAG

    %% Query flow
    API --> QueryEmbed
    QueryEmbed --> VectorSearch
    VectorSearch -->|"similarity search"| VectorStore
    VectorSearch --> RAG
    RAG --> Response
    Response --> API

    %% Phase 2+ automated trigger
    AutoTrigger -.->|"Phase 2+"| API

    %% Config drives services (scoped — ADR-015)
    ExpressConfig -.->|"Provider selection"| API
    PythonConfig -.->|"Provider selection"| OCR

    %% Pipeline tracking
    DB -.->|"Step status read"| PipelineTracker

    %% Styling
    style DB fill:#99d6ff
    style Storage fill:#99d6ff
    style ExpressConfig fill:#ffffcc
    style PythonConfig fill:#ffffcc
    style Response fill:#a8d5a8
    style Archivist fill:#ffb366
    style C4 fill:#f0f0f0,stroke-dasharray: 5 5
    style AutoTrigger fill:#f0f0f0,stroke-dasharray: 5 5
